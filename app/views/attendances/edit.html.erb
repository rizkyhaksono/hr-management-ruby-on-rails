<% content_for(:breadcrumbs) do %>
  <%= breadcrumbs({ label: "Home", path: root_path }, { label: "Absensi", path: attendances_path }, { label: "Edit" }) %>
<% end %>

<div class="page-header">
  <div class="page-header-content">
    <h1>Edit Absensi</h1>
    <p class="subtitle">Perbarui data absensi <%= @attendance.employee.full_name %></p>
  </div>
  <%= link_to attendance_path(@attendance), class: "btn btn-secondary" do %><%= icon(:arrow_left) %> Kembali<% end %>
</div>

<div class="card">
  <div class="card-body">
    <%= render "form", attendance: @attendance %>
  </div>
</div>
