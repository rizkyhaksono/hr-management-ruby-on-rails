<% content_for(:breadcrumbs) do %>
  <%= breadcrumbs({ label: "Home", path: root_path }, { label: "Absensi", path: attendances_path }, { label: "Tambah Baru" }) %>
<% end %>

<div class="page-header">
  <div class="page-header-content">
    <h1>Tambah Absensi</h1>
    <p class="subtitle">Catat kehadiran karyawan</p>
  </div>
  <%= link_to attendances_path, class: "btn btn-secondary" do %><%= icon(:arrow_left) %> Kembali<% end %>
</div>

<div class="card">
  <div class="card-body">
    <%= render "form", attendance: @attendance %>
  </div>
</div>
