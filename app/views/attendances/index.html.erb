<% content_for(:breadcrumbs) do %>
  <%= breadcrumbs({ label: "Home", path: root_path }, { label: "Absensi" }) %>
<% end %>

<div class="page-header">
  <div class="page-header-content">
    <h1>Data Absensi</h1>
    <p class="subtitle">Kelola kehadiran karyawan</p>
  </div>
  <div class="header-actions">
    <%= link_to attendances_path(format: :csv, **request.query_parameters.except(:page)), class: "btn btn-secondary" do %>
      <%= icon(:download) %> Export CSV
    <% end %>
    <%= link_to bulk_create_attendances_path, class: "btn btn-secondary" do %>
      <%= icon(:users) %> Absensi Massal
    <% end %>
    <%= link_to new_attendance_path, class: "btn btn-primary" do %>
      <%= icon(:plus) %> Tambah Absensi
    <% end %>
  </div>
</div>

<div class="filters-bar">
  <%= form_tag attendances_path, method: :get, class: "filter-form" do %>
    <div class="filter-group">
      <%= date_field_tag :date, params[:date], class: "form-input", placeholder: "Pilih tanggal" %>
      <%= select_tag :employee_id, options_for_select([["Semua Karyawan", ""]] + @employees.map { |e| [e.full_name, e.id] }, params[:employee_id]), class: "form-select" %>
      <%= select_tag :status, options_for_select([["Semua Status", ""], ["Hadir", "present"], ["Absen", "absent"], ["Terlambat", "late"], ["Setengah Hari", "half_day"], ["Remote", "remote"]], params[:status]), class: "form-select" %>
      <button type="submit" class="btn btn-secondary"><%= icon(:filter) %> Filter</button>
    </div>
  <% end %>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table">
      <thead>
        <tr>
          <th>Karyawan</th>
          <th>Tanggal</th>
          <th>Masuk</th>
          <th>Keluar</th>
          <th>Durasi</th>
          <th>Status</th>
          <th>Catatan</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% @attendances.each do |attendance| %>
          <tr>
            <td>
              <div class="employee-name">
                <div class="avatar"><%= attendance.employee.initials %></div>
                <strong><%= attendance.employee.full_name %></strong>
              </div>
            </td>
            <td><%= attendance.date.strftime("%d/%m/%Y") %></td>
            <td><%= attendance.check_in&.strftime("%H:%M") || "-" %></td>
            <td><%= attendance.check_out&.strftime("%H:%M") || "-" %></td>
            <td><%= attendance.working_hours_text %></td>
            <td><span class="badge badge-<%= attendance.status %>"><%= attendance.status.humanize %></span></td>
            <td class="text-truncate"><%= attendance.notes || "-" %></td>
            <td class="actions">
              <%= link_to edit_attendance_path(attendance), class: "btn btn-sm btn-secondary", title: "Edit" do %><%= icon(:pencil) %><% end %>
              <%= link_to attendance_path(attendance), data: { turbo_method: :delete, turbo_confirm: "Yakin hapus data ini?" }, class: "btn btn-sm btn-danger", title: "Hapus" do %><%= icon(:trash) %><% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @attendances.empty? %>
    <div class="empty-state">
      <div class="empty-state-icon"><%= icon(:clock) %></div>
      <h3>Belum ada data absensi</h3>
      <p>Mulai dengan mencatat absensi karyawan.</p>
      <%= link_to new_attendance_path, class: "btn btn-primary" do %>
        <%= icon(:plus) %> Tambah Absensi
      <% end %>
    </div>
  <% end %>

  <%= render "shared/pagination", total_pages: @total_pages, current_page: @current_page %>
</div>
