<%= form_with(model: leave, class: "form") do |f| %>
  <% if leave.errors.any? %>
    <div class="alert alert-danger">
      <h4>⚠️ Terdapat <%= leave.errors.count %> kesalahan:</h4>
      <ul>
        <% leave.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-2">
    <div class="form-group">
      <%= f.label :employee_id, "Karyawan", class: "form-label" %>
      <%= f.collection_select :employee_id, @employees, :id, :full_name, { prompt: "Pilih Karyawan" }, class: "form-select" %>
    </div>

    <div class="form-group">
      <%= f.label :leave_type, "Tipe Cuti", class: "form-label" %>
      <%= f.select :leave_type, Leave.leave_types.keys.map { |t| [t.humanize, t] }, { prompt: "Pilih Tipe" }, class: "form-select" %>
    </div>

    <div class="form-group">
      <%= f.label :start_date, "Tanggal Mulai", class: "form-label" %>
      <%= f.date_field :start_date, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= f.label :end_date, "Tanggal Selesai", class: "form-label" %>
      <%= f.date_field :end_date, class: "form-input" %>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :reason, "Alasan", class: "form-label" %>
    <%= f.text_area :reason, class: "form-input", rows: 4, placeholder: "Tuliskan alasan cuti..." %>
  </div>

  <div class="form-actions">
    <%= f.submit leave.new_record? ? "💾 Ajukan Cuti" : "💾 Update Cuti", class: "btn btn-primary" %>
    <%= link_to "Batal", leaves_path, class: "btn btn-secondary" %>
  </div>
<% end %>
