<% content_for(:breadcrumbs) do %>
  <%= breadcrumbs({ label: "Home", path: root_path }, { label: "Cuti" }) %>
<% end %>

<div class="page-header">
  <div class="page-header-content">
    <h1>Manajemen Cuti</h1>
    <p class="subtitle">Kelola pengajuan dan persetujuan cuti</p>
  </div>
  <div class="header-actions">
    <%= link_to leaves_path(format: :csv, **request.query_parameters.except(:page)), class: "btn btn-secondary" do %>
      <%= icon(:download) %> Export CSV
    <% end %>
    <%= link_to new_leave_path, class: "btn btn-primary" do %>
      <%= icon(:plus) %> Ajukan Cuti
    <% end %>
  </div>
</div>

<div class="filters-bar">
  <%= form_tag leaves_path, method: :get, class: "filter-form" do %>
    <div class="filter-group">
      <%= select_tag :status, options_for_select([["Semua Status", ""], ["Pending", "pending"], ["Disetujui", "approved"], ["Ditolak", "rejected"], ["Dibatalkan", "cancelled"]], params[:status]), class: "form-select" %>
      <%= select_tag :leave_type, options_for_select([["Semua Tipe", ""], ["Tahunan", "annual"], ["Sakit", "sick"], ["Pribadi", "personal"], ["Melahirkan", "maternity"], ["Paternity", "paternity"], ["Tanpa Gaji", "unpaid"]], params[:leave_type]), class: "form-select" %>
      <button type="submit" class="btn btn-secondary"><%= icon(:filter) %> Filter</button>
    </div>
  <% end %>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table">
      <thead>
        <tr>
          <th>Karyawan</th>
          <th>Tipe Cuti</th>
          <th>Mulai</th>
          <th>Selesai</th>
          <th>Durasi</th>
          <th>Status</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% @leaves.each do |leave| %>
          <tr>
            <td>
              <div class="employee-name">
                <div class="avatar"><%= leave.employee.initials %></div>
                <div>
                  <strong><%= leave.employee.full_name %></strong>
                  <small><%= leave.employee.department %></small>
                </div>
              </div>
            </td>
            <td><span class="badge badge-type-<%= leave.leave_type %>"><%= leave.leave_type.humanize %></span></td>
            <td><%= leave.start_date.strftime("%d/%m/%Y") %></td>
            <td><%= leave.end_date.strftime("%d/%m/%Y") %></td>
            <td><%= leave.duration_text %></td>
            <td><span class="badge badge-<%= leave.status %>"><%= leave.status.humanize %></span></td>
            <td class="actions">
              <%= link_to leave_path(leave), class: "btn btn-sm btn-secondary", title: "Detail" do %><%= icon(:eye) %><% end %>
              <% if leave.pending? %>
                <%= link_to approve_leave_path(leave), data: { turbo_method: :patch, turbo_confirm: "Setujui cuti ini?" }, class: "btn btn-sm btn-success", title: "Setujui" do %><%= icon(:check) %><% end %>
                <%= link_to reject_leave_path(leave), data: { turbo_method: :patch, turbo_confirm: "Tolak cuti ini?" }, class: "btn btn-sm btn-danger", title: "Tolak" do %><%= icon(:x) %><% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @leaves.empty? %>
    <div class="empty-state">
      <div class="empty-state-icon"><%= icon(:calendar) %></div>
      <h3>Belum ada data cuti</h3>
      <p>Mulai dengan mengajukan cuti.</p>
      <%= link_to new_leave_path, class: "btn btn-primary" do %>
        <%= icon(:plus) %> Ajukan Cuti
      <% end %>
    </div>
  <% end %>

  <%= render "shared/pagination", total_pages: @total_pages, current_page: @current_page %>
</div>
