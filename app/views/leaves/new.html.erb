<% content_for(:breadcrumbs) do %>
  <%= breadcrumbs({ label: "Home", path: root_path }, { label: "Cuti", path: leaves_path }, { label: "Ajukan Baru" }) %>
<% end %>

<div class="page-header">
  <div class="page-header-content">
    <h1>Ajukan Cuti</h1>
    <p class="subtitle">Buat pengajuan cuti baru</p>
  </div>
  <%= link_to leaves_path, class: "btn btn-secondary" do %><%= icon(:arrow_left) %> Kembali<% end %>
</div>

<div class="card">
  <div class="card-body">
    <%= render "form", leave: @leave %>
  </div>
</div>
