<% content_for(:breadcrumbs) do %>
  <%= breadcrumbs({ label: "Home", path: root_path }, { label: "Karyawan", path: employees_path }, { label: @employee.full_name }) %>
<% end %>

<div class="page-header">
  <div class="page-header-content">
    <h1><%= @employee.full_name %></h1>
    <p class="subtitle"><%= @employee.position %> &mdash; <%= @employee.department %></p>
  </div>
  <div class="header-actions">
    <%= link_to edit_employee_path(@employee), class: "btn btn-secondary" do %><%= icon(:pencil) %> Edit<% end %>
    <%= link_to employees_path, class: "btn btn-secondary" do %><%= icon(:arrow_left) %> Kembali<% end %>
  </div>
</div>

<!-- Summary Stats -->
<div class="grid grid-4" style="margin-bottom: 1.5rem;">
  <div class="stat-card stat-card-blue">
    <div class="stat-icon-wrap"><%= icon(:briefcase) %></div>
    <div class="stat-info">
      <span class="stat-label">Masa Kerja</span>
      <span class="stat-value"><%= @employee.years_of_service %> Tahun</span>
    </div>
  </div>
  <div class="stat-card stat-card-green">
    <div class="stat-icon-wrap"><%= icon(:calendar) %></div>
    <div class="stat-info">
      <span class="stat-label">Sisa Cuti</span>
      <span class="stat-value"><%= @employee.leave_balance %> Hari</span>
    </div>
  </div>
  <div class="stat-card stat-card-orange">
    <div class="stat-icon-wrap"><%= icon(:clock) %></div>
    <div class="stat-info">
      <span class="stat-label">Cuti Terpakai</span>
      <span class="stat-value"><%= @employee.total_leaves_this_year %> Hari</span>
    </div>
  </div>
  <div class="stat-card stat-card-purple">
    <div class="stat-icon-wrap"><%= icon(:activity) %></div>
    <div class="stat-info">
      <span class="stat-label">Kehadiran</span>
      <span class="stat-value"><%= @employee.attendance_rate_this_month %>%</span>
    </div>
  </div>
</div>

<!-- Leave Balance -->
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card-body">
    <div class="leave-balance" style="--ring-percent: <%= @employee.leave_usage_percent %>%;">
      <div class="leave-balance-ring"></div>
      <div class="leave-balance-info">
        <strong>Kuota Cuti Tahunan: <%= @employee.leave_quota || 12 %> hari</strong>
        <small>Terpakai: <%= @employee.total_leaves_this_year %> hari &middot; Sisa: <%= @employee.leave_balance %> hari</small>
      </div>
      <%= link_to new_leave_path(employee_id: @employee.id), class: "btn btn-sm btn-primary" do %><%= icon(:plus) %> Ajukan Cuti<% end %>
    </div>
  </div>
</div>

<!-- Details -->
<div class="grid grid-2" style="margin-bottom: 1.5rem;">
  <div class="card">
    <div class="card-header">
      <h3><%= icon(:user) %> Informasi Pribadi</h3>
    </div>
    <div class="card-body">
      <div class="detail-row">
        <span class="detail-label">ID Karyawan</span>
        <span class="detail-value"><span class="badge badge-light"><%= @employee.employee_id %></span></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Nama Lengkap</span>
        <span class="detail-value"><%= @employee.full_name %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Email</span>
        <span class="detail-value"><%= @employee.email %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Telepon</span>
        <span class="detail-value"><%= @employee.phone || "-" %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Status</span>
        <span class="detail-value"><span class="badge badge-<%= @employee.status %>"><%= @employee.status.humanize %></span></span>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <h3><%= icon(:building) %> Informasi Pekerjaan</h3>
    </div>
    <div class="card-body">
      <div class="detail-row">
        <span class="detail-label">Departemen</span>
        <span class="detail-value"><%= @employee.department %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Jabatan</span>
        <span class="detail-value"><%= @employee.position %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Tanggal Masuk</span>
        <span class="detail-value"><%= @employee.hire_date&.strftime("%d %B %Y") %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Gaji</span>
        <span class="detail-value"><%= format_currency(@employee.salary) %></span>
      </div>
    </div>
  </div>
</div>

<!-- History -->
<div class="grid grid-2">
  <div class="card">
    <div class="card-header">
      <h3><%= icon(:calendar) %> Riwayat Cuti</h3>
      <%= link_to "Lihat Semua", leaves_path(employee_id: @employee.id), class: "btn btn-sm btn-secondary" %>
    </div>
    <div class="card-body">
      <% if @recent_leaves.any? %>
        <table class="table table-sm">
          <thead><tr><th>Tipe</th><th>Tanggal</th><th>Status</th></tr></thead>
          <tbody>
            <% @recent_leaves.each do |leave| %>
              <tr>
                <td><span class="badge badge-type-<%= leave.leave_type %>"><%= leave.leave_type.humanize %></span></td>
                <td><%= leave.start_date.strftime("%d/%m/%Y") %> - <%= leave.end_date.strftime("%d/%m/%Y") %></td>
                <td><span class="badge badge-<%= leave.status %>"><%= leave.status.humanize %></span></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-muted text-center">Belum ada data cuti</p>
      <% end %>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <h3><%= icon(:clock) %> Absensi Terakhir</h3>
      <%= link_to "Lihat Semua", attendances_path(employee_id: @employee.id), class: "btn btn-sm btn-secondary" %>
    </div>
    <div class="card-body">
      <% if @recent_attendances.any? %>
        <table class="table table-sm">
          <thead><tr><th>Tanggal</th><th>Masuk</th><th>Keluar</th><th>Status</th></tr></thead>
          <tbody>
            <% @recent_attendances.each do |att| %>
              <tr>
                <td><%= att.date.strftime("%d/%m/%Y") %></td>
                <td><%= att.check_in&.strftime("%H:%M") || "-" %></td>
                <td><%= att.check_out&.strftime("%H:%M") || "-" %></td>
                <td><span class="badge badge-<%= att.status %>"><%= att.status.humanize %></span></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-muted text-center">Belum ada data absensi</p>
      <% end %>
    </div>
  </div>
</div>
