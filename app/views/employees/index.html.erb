<div class="page-header">
  <div class="page-header-content">
    <h1>👥 Data Karyawan</h1>
    <p class="subtitle">Kelola data karyawan perusahaan</p>
  </div>
  <%= link_to "➕ Tambah Karyawan", new_employee_path, class: "btn btn-primary" %>
</div>

<div class="filters-bar">
  <%= form_tag employees_path, method: :get, class: "filter-form" do %>
    <div class="filter-group">
      <%= text_field_tag :search, params[:search], placeholder: "Cari nama, email, ID...", class: "form-input" %>
      <%= select_tag :department, options_for_select([["Semua Departemen", ""]] + @departments.map { |d| [d, d] }, params[:department]), class: "form-select" %>
      <%= select_tag :status, options_for_select([["Semua Status", ""], ["Aktif", "active"], ["Tidak Aktif", "inactive"], ["Cuti", "on_leave"], ["Resign", "terminated"]], params[:status]), class: "form-select" %>
      <button type="submit" class="btn btn-secondary">🔍 Filter</button>
    </div>
  <% end %>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Nama</th>
          <th>Email</th>
          <th>Departemen</th>
          <th>Jabatan</th>
          <th>Status</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% @employees.each do |employee| %>
          <tr>
            <td><span class="badge badge-light"><%= employee.employee_id %></span></td>
            <td>
              <div class="employee-name">
                <div class="avatar"><%= employee.first_name[0] %><%= employee.last_name[0] %></div>
                <div>
                  <strong><%= employee.full_name %></strong>
                  <small class="text-muted"><%= employee.phone %></small>
                </div>
              </div>
            </td>
            <td><%= employee.email %></td>
            <td><%= employee.department %></td>
            <td><%= employee.position %></td>
            <td><span class="badge badge-<%= employee.status %>"><%= employee.status.humanize %></span></td>
            <td class="actions">
              <%= link_to "👁", employee_path(employee), class: "btn btn-sm btn-info", title: "Detail" %>
              <%= link_to "✏️", edit_employee_path(employee), class: "btn btn-sm btn-warning", title: "Edit" %>
              <%= link_to "🗑", employee_path(employee), data: { turbo_method: :delete, turbo_confirm: "Yakin hapus #{employee.full_name}?" }, class: "btn btn-sm btn-danger", title: "Hapus" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @employees.empty? %>
    <div class="empty-state">
      <p>📋 Belum ada data karyawan</p>
      <%= link_to "Tambah Karyawan Pertama", new_employee_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>